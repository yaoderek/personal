---
import { getCollection } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import OsPage from '../../layouts/OsPage.astro';
import { formatDate } from '../../lib/os/format';

export async function getStaticPaths() {
  const art = await getCollection('art');
  return art.map((entry) => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const optimized = await getImage({ src: data.image, width: 1200, format: 'webp' });
const ogImage = optimized.src;
const dateIso = data.created.toISOString().slice(0, 10);
---

<OsPage
  initialPath={`/art/${data.id}`}
  title={`${data.title} — Derek Yao`}
  description={`${data.title} — ${data.medium} by Derek Yao.`}
  ogImage={ogImage}
>
  <article>
    <p><a href="/art">← art</a></p>
    <h1>{data.title}</h1>
    <Image src={data.image} alt={data.title} width={1200} />
    <dl>
      <dt>Medium</dt>
      <dd>{data.medium}</dd>
      <dt>Created</dt>
      <dd><time datetime={dateIso}>{formatDate(dateIso)}</time></dd>
    </dl>
  </article>
</OsPage>

---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import OsPage from '../../layouts/OsPage.astro';

const art = await getCollection('art');
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<OsPage
  initialPath="/art"
  title="Art — Derek Yao"
  description="A gallery of digital art by Derek Yao."
>
  <h1>Art</h1>
  <p><a href={`${base}/`}>← derek's mac</a></p>
  <div class="grid">
    {art.map((piece) => (
      <figure>
        <a href={`${base}/art/${piece.data.id}`}>
          <Image
            src={piece.data.image}
            alt={piece.data.title}
            width={800}
          />
        </a>
        <figcaption>{piece.data.title}</figcaption>
      </figure>
    ))}
  </div>
</OsPage>

<style is:global>
  .noscript-content .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .noscript-content figure {
    margin: 0;
  }
  .noscript-content figcaption {
    font-size: 0.85rem;
    color: #6e6e73;
    margin-top: 0.25rem;
  }
</style>

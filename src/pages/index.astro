---
import OsPage from '../layouts/OsPage.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<OsPage
  initialPath={null}
  title="Derek Yao"
  description="Derek Yao — projects, writing, art. A fake little Mac as a personal website."
>
  <h1>Derek Yao</h1>
  <p>
    Hi, I'm Derek — working as a member of technical staff at Contour (backed
    by Lightspeed, Chemistry) this summer. I'm a student at UW studying art
    and computer science. I've worked with Oracle on supply chain resilience
    and optimization, and I'm currently building agentic research systems with
    the Denolle and GAIA labs at UW.
  </p>
  <p>This site is a fake little Mac.</p>
  <ul>
    <li><a href={`${base}/projects`}>/projects</a> — things I've built</li>
    <li><a href={`${base}/writing`}>/writing</a> — notes and essays</li>
    <li><a href={`${base}/art`}>/art</a> — pictures</li>
  </ul>
  <ul>
    <li><a href="mailto:yaoderek06@gmail.com">yaoderek06@gmail.com</a></li>
    <li><a href="https://github.com/yaoderek">github.com/yaoderek</a></li>
    <li><a href="https://linkedin.com/in/yaoderek">linkedin.com/in/yaoderek</a></li>
  </ul>
</OsPage>

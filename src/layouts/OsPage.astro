---
import { getImage } from 'astro:assets';
import { getDesktopProps } from '../lib/os/tree-data';
import Desktop from '../components/os/Desktop.svelte';
import wallpaperSrc from '../assets/wallpaper.jpg';
import '../styles/global.css';

interface Props {
  initialPath?: string | null;
  title: string;
  description: string;
  ogImage?: string | null;
  notFound?: boolean;
}

const {
  initialPath = null,
  title,
  description,
  ogImage = null,
  notFound = false,
} = Astro.props;

const { tree, showResume } = await getDesktopProps();
const wallpaper = await getImage({
  src: wallpaperSrc,
  format: 'webp',
  width: 2560,
  quality: 72,
});
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : null;
const canonicalHref = canonicalUrl?.href ?? null;
const ogImageAbsolute =
  ogImage && Astro.site
    ? new URL(ogImage, Astro.site).href
    : ogImage;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalHref && <meta property="og:url" content={canonicalHref} />}
    {ogImageAbsolute && <meta property="og:image" content={ogImageAbsolute} />}
  </head>
  <body>
    <Desktop
      client:only="svelte"
      tree={tree}
      initialPath={initialPath}
      showResume={showResume}
      notFound={notFound}
      wallpaperUrl={wallpaper.src}
    />
    <noscript>
      <main class="noscript-content">
        <slot />
      </main>
    </noscript>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  /* The desktop island replaces the viewport when JS runs; the noscript
     fallback is the real crawlable / no-JS page, so let it scroll. */
  .noscript-content {
    display: block;
    max-width: 44rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    overflow: auto;
    height: auto;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    color: #1d1d1f;
  }

  .noscript-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .noscript-content a {
    color: #0066cc;
  }
</style>
